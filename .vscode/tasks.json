{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Watch Dashboard",
      "type": "shell",
      "command": "powershell -ExecutionPolicy Bypass -Command \"& ([scriptblock]::Create((Get-Content '${workspaceFolder}\\docs\\dashboard\\sync-dashboard.ps1' -Raw))) -Dir '${workspaceFolder}\\docs\\dashboard'\"",
      "isBackground": true,
      "problemMatcher": [],
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "label": "Dashboard Watcher"
      },
      "runOptions": {
        "runOn": "folderOpen"
      }
    },
    {
      "label": "Fetch Clone Stats",
      "type": "shell",
      "command": "powershell -ExecutionPolicy Bypass -Command \"& ([scriptblock]::Create((Get-Content '${workspaceFolder}\\validations\\scripts\\fetch-clone-stats.ps1' -Raw))) -WorkspaceRoot '${workspaceFolder}'\"",
      "isBackground": false,
      "problemMatcher": [],
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "label": "Clone Stats"
      }
    }
  ]
}
